NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — never prefix this with NEXT_PUBLIC_. It grants full admin
# access to your Supabase project (bypasses all security rules). Used only
# by the admin panel to reset passwords and ban/unban accounts.
SUPABASE_SERVICE_ROLE_KEY=your-secret-key
